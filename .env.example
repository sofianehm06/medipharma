# ============================================================
#  MediPharma — Variables d'environnement Docker
#  Copier ce fichier en .env et remplir les valeurs
# ============================================================

# ── MySQL ──────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=ChangeMoi_Root_2026!
MYSQL_PASSWORD=ChangeMoi_Pharm_2026!

# ── JWT (générer avec : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=remplacer_par_une_chaine_aleatoire_de_64_caracteres_minimum

# ── OpenAI (optionnel — laisser vide pour désactiver l'IA)
OPENAI_API_KEY=sk-votre-cle-openai-ici

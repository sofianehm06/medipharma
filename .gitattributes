# Normaliser les fins de ligne automatiquement
* text=auto

# Scripts shell : LF obligatoire
*.sh    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.json  text eol=lf
*.js    text eol=lf
*.jsx   text eol=lf
*.css   text eol=lf
*.html  text eol=lf
*.sql   text eol=lf
*.md    text eol=lf

# Binaires
*.png   binary
*.jpg   binary
*.ico   binary
